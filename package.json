{
  "name": "bm-order-confirmation",
  "version": "0.1.0",
  "private": true,
  "description": "Customer-facing order confirmation portal + internal sales admin. First module of the BeastMode sales platform.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env.local src/db/seed.ts",
    "db:seed-demo": "tsx --env-file=.env.local src/db/seed-demo.ts",
    "db:seed-demo-extra": "tsx --env-file=.env.local src/db/seed-demo-extra.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude \"**/*.integration.test.ts\"",
    "test:integration": "vitest run integration",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.2",
    "@ant-design/nextjs-registry": "^1.0.2",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@react-pdf/renderer": "^4.5.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react-signature-canvas": "^1.0.7",
    "antd": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.38.0",
    "iron-session": "^8.0.4",
    "next": "^15.1.0",
    "nodemailer": "^9.0.1",
    "otplib": "^13.4.1",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "recharts": "^3.9.0",
    "tsx": "^4.22.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
