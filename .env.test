# Loaded by vitest.setup.ts for all test runs. Dummy, schema-valid values only — never real secrets.
# DATABASE_URL is a placeholder: integration tests inject a PGlite-backed db via vi.mock('@/db', ...)
# and never actually connect to this URL.
DATABASE_URL="postgresql://test:test@localhost:5432/test"
APP_BASE_URL="http://localhost:3000"
TOKEN_PEPPER="test-pepper-not-a-real-secret-0123456789"
INTERNAL_API_KEY="test-internal-api-key-0123456789"
SESSION_SECRET="test-session-secret-at-least-32-characters-long"
