# Copy to .env.local for development. NEVER commit real secrets.

# --- Database (Supabase Postgres or any Postgres) ---
# DATABASE_URL: pooled connection (port 6543) used by the app at runtime.
# DATABASE_DIRECT_URL: direct connection (port 5432) used by drizzle-kit for DDL migrations.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres"
DATABASE_DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# --- App ---
# Public base URL used to build customer confirmation links: {APP_BASE_URL}/o/{token}
APP_BASE_URL="http://localhost:3000"

# Secret pepper mixed into the token hash before storage. Generate a long random value.
# e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_PEPPER="change-me-to-a-long-random-string"

# --- Internal service auth (the /api/orders ingestion seam, see PROJECT_BRIEF.md §15) ---
# Shared secret the admin UI / future sales platform sends as x-api-key. Stub for now.
INTERNAL_API_KEY="change-me-internal-api-key"

# --- Staff session (iron-session encrypted cookie) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters.
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# --- First admin user (used by npm run db:seed only — never commit real values) ---
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me"
SEED_ADMIN_NAME="Admin"

# --- Email (Mailgun) — not wired yet, placeholders for when link delivery is added ---
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
MAIL_FROM="orders@example.com"

# --- Google Ads conversion (server-side, added later — see PROJECT_BRIEF.md §10) ---
GOOGLE_ADS_CONVERSION_ID=""
GOOGLE_ADS_CONVERSION_LABEL=""
