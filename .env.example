# Copy to .env.local for development. NEVER commit real secrets.

# --- Database (Supabase Postgres or any Postgres) ---
# DATABASE_URL: pooled connection (port 6543) used by the app at runtime.
# DATABASE_DIRECT_URL: direct connection (port 5432) used by drizzle-kit for DDL migrations.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres"
DATABASE_DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# --- App ---
# Public base URL used to build customer confirmation links: {APP_BASE_URL}/o/{token}
APP_BASE_URL="http://localhost:3000"

# Secret pepper mixed into the token hash before storage. Generate a long random value.
# e.g. node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_PEPPER="change-me-to-a-long-random-string"

# --- Internal service auth (the /api/orders ingestion seam, see PROJECT_BRIEF.md §15) ---
# Shared secret the admin UI / future sales platform sends as x-api-key. Stub for now.
INTERNAL_API_KEY="change-me-internal-api-key"

# --- Staff session (iron-session encrypted cookie) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters.
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# --- First admin user (used by npm run db:seed only — never commit real values) ---
SEED_ADMIN_EMAIL="admin@yourdomain.com"
SEED_ADMIN_PASSWORD="change-me"
SEED_ADMIN_NAME="Admin"

# --- Cron auth (optional — only needed if using Vercel Cron to trigger the outbox) ---
# Vercel sets this automatically and sends it as `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=""

# --- Customer magic-link expiry (optional) ---
# Days a magic link stays valid after creation. Leave unset for links that never expire.
# Suggested value once enabled: 30. Staff can always mint a fresh link via "Resend link".
LINK_EXPIRY_DAYS=""

# --- File storage (S3-compatible, e.g. Supabase Storage) ---
# Uploads fail gracefully if unset — configure before going live.
AWS_S3_BUCKET=""
AWS_S3_REGION=""
AWS_S3_ACCESS_KEY=""
AWS_S3_SECRET_ACCESS_KEY=""

# --- Email (SMTP) ---
# Leave SMTP_HOST unset to disable email (links must be shared manually).
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="true"          # true = TLS (port 465); false = STARTTLS (port 587)
MAIL_FROM="orders@example.com"
STAFF_NOTIFICATIONS_CC=""   # Optional team inbox CC for staff notification emails

# --- Google Tag Manager (client-side conversion tracking — see PROJECT_BRIEF.md §10) ---
# Get from GTM > Admin > Container Settings. Leave empty to disable GTM injection.
NEXT_PUBLIC_GTM_ID=""

# --- Google Ads Enhanced Conversions (client-side GTM tag params) ---
GOOGLE_ADS_CONVERSION_ID=""
GOOGLE_ADS_CONVERSION_LABEL=""

# --- Google Ads Enhanced Conversions (server-side API upload) ---
# All six must be set together; leave any unset to disable server-side firing.
GOOGLE_ADS_CUSTOMER_ID=""
GOOGLE_ADS_CONVERSION_ACTION_ID=""
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_OAUTH_CLIENT_ID=""
GOOGLE_ADS_OAUTH_CLIENT_SECRET=""
GOOGLE_ADS_OAUTH_REFRESH_TOKEN=""

# --- Error monitoring (optional) ---
# src/lib/logger.ts sends logger.error() calls to Sentry's envelope ingestion
# API when set (plain fetch, no SDK). Leave unset to disable — errors still
# log to stdout as structured JSON either way.
SENTRY_DSN=""
